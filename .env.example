# Public frontend runtime config (safe to expose)
NEXT_PUBLIC_PRIMARY_DOMAIN=earnsigma.com
# Non-production only: host suffixes accepted by proxy.ts (preview/dev)
NEXT_PUBLIC_ALLOWED_HOST_SUFFIXES=.vercel.app,.localhost
NEXT_PUBLIC_API_BASE_URL=https://api.earnsigma.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: only if billing UI reads Stripe publishable key in your deployment
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx

# OpenAPI generation inputs for this frontend repo
# OPENAPI_SCHEMA_URL=https://api.earnsigma.com/openapi.json
# OPENAPI_TYPES_OUT=src/lib/api/generated/schema.ts

# Backend deploy env vars (set these on the backend service, not this frontend app)
# STRIPE_CHECKOUT_URL_PLAN_A=https://checkout.stripe.com/...
# STRIPE_CHECKOUT_URL_PLAN_B=https://checkout.stripe.com/...
