{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@earnsigma/brand": [
        "./packages/brand/src/index.ts"
      ],
      "@earnsigma/brand/*": [
        "./packages/brand/src/*"
      ],
      "@earnsigma/ui": [
        "./packages/ui/src/index.ts"
      ],
      "@earnsigma/ui/*": [
        "./packages/ui/src/*"
      ],
      "@earnsigma/config": [
        "./packages/config/src/index.ts"
      ],
      "@earnsigma/config/*": [
        "./packages/config/src/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "tests/e2e/**/*.ts"
  ]
}
